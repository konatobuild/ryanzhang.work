# Hoist every dependency to the workspace root's node_modules/.
#
# Why: each Next.js app pins `turbopack.root` to the monorepo root so Next
# does not walk up to /Users/$USER and pick up a stray lockfile. Turbopack
# then resolves `next/package.json` starting from that root. With pnpm's
# default isolated linker plus `enableGlobalVirtualStore: true`, the worktree
# root's node_modules/ holds only .pnpm metadata — no top-level `next`
# symlink — and the build fails with "Next.js inferred your workspace root,
# but it may not be correct." Shamefully hoisting keeps a top-level link
# to `next` so Turbopack finds it.
#
# Cost: slightly larger worktree node_modules/ (still de-duped via the
# global content store); no effect on install time.
shamefully-hoist=true
